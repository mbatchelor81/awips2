<!-- L. Byerle 1/16/2020 added snowfall rate SFR (e.g. ATMS SFR). Define SICP for SIce. SICP is parameter with units
                          percent (vs %), to match ATMS files
      2/6/2020 removed erroneous abbreviation tag 
      1/1/2023 remove triangulation to fix occn'l plot issue found most recently by Carl Dierking w/SFR -->
<pointSetProductDescriptions>
  <default>
    <matches>
      <match pattern="ATMS">
        <attribute name="instrument_name"/>
      </match>
    </matches>
    <dataTime>
      <formattedRefTime dateFormat="yyyy-MM-dd'T'HH:mm:ss'Z'">
        <attribute name="time_coverage_start"/>
      </formattedRefTime>
    </dataTime>
    <datasetId>
      <attribute name="instrument_name"/>
    </datasetId>
<!--    <triangulation type="grid"/> -->
    <latitude name="Latitude"/>
    <longitude name="Longitude"/>
    <level>
      <masterLevel>
        <value value="EA"/>
      </masterLevel>
      <levelOneValue>
        <value value="0.0"/>
      </levelOneValue>
    </level>
  </default>
  <description>
    <data>
      <variable name="CLW"/>
      <discreteMask name="CLW" value="-999" keep="false">
          <fillFloat>NaN</fillFloat>
        </discreteMask>
    </data>
    <parameter>
      <abbreviation>
        <value value="CLW"/>
      </abbreviation>
    </parameter>
  </description>
  <description>
    <data>
      <variable name="RR"/>
    </data>
    <parameter>
      <abbreviation>
      <!--  <value value="RR" /> -->
      <!-- Avoids conflict with radar reflectivity RR derived parameter 11/14/2016 -->
        <value value="Rain_Rate" />
      </abbreviation>
    </parameter>
  </description>

  <description>
    <data>
      <variable name="SIce"/>
    </data>
    <parameter>
      <abbreviation>
        <value value="SICP"/>
      </abbreviation>
    </parameter>
  </description>

  <description>
    <data>
      <variable name="SWE"/>
    </data>
    <parameter>
      <abbreviation>
        <value value="SWE"/>
      </abbreviation>
    </parameter>
  </description>
  <description>
    <data>
      <variable name="Snow"/>
    </data>
    <parameter>
      <abbreviation>
        <value value="SNOW"/>
      </abbreviation>
    </parameter>
  </description>
  <description>
    <data>
      <variable name="SFR" />
    </data>
    <parameter>
      <abbreviation>
        <value value="SFR" />
      </abbreviation>
    </parameter>
  </description>
  <description>
    <data>
      <variable name="TSkin" />
    </data>
    <parameter>
      <abbreviation>
        <value value="TSkin" />
      </abbreviation>
    </parameter>
  </description>
  <description>
    <data>
      <variable name="TPW"/>
    </data>
    <parameter>
      <abbreviation>
        <value value="TPW"/>
      </abbreviation>
    </parameter>
  </description>
</pointSetProductDescriptions>


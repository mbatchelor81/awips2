    <!-- TOWRdocs Header
         AMSR2 Pointset plugin product descriptions.
    -->
    <!-- TOWRdocs Description
         Provides descriptions for AMSR2 products handled by the pointset plugin. 

         The data name, time_coverage_start, dateFormat, and instrument_name refer to
         expected fields from each of the instrument netCDF files.

         parameterValue must match a parameter defined in the ../../parameter/definition/ files. 
         "EA" refers to entire atmosphere.

         The following products are currently described by this file:

         GCOM-W1 AMSR2 36.5GHz Horizontal/Vertical -A
         GCOM-W1 AMSR2 89.0GHz Horizontal/Vertical -B
         GCOM-W1 AMSR2 Surface Wind Speed (WSPD)
         GCOM-W1 AMSR2 Cloud Liquid Water (CLW)
         GCOM-W1 AMSR2 TPW 
         GCOM-W1 AMSR2 Sea Surface Temp (SST)
         GCOM-W1 AMSR2 rain rates (Rain_Rate)

         The formattedRefTime for AMSR2 and GMI/ATMS are different.
         AMSR2: yyyy-MM-dd'T'HH:mm:ss.S'Z'
         GMI, ATMS: yyyy-MM-dd'T'HH:mm:ss'Z'

         Corresponding parameter abbreviations listed for each variable are located
         under ../../parameter/definition/amsr2_microwave_parameters.xml.
         That file contains param defs for AMSR2, ATMS, and GMI fields.
         Restart edex for the changes in this file to go into affect.


         Restart edex for the changes in this file to go into affect.
    
   -->
    <!-- TOWRdocs Status
         Update this file as needed when adding AMSR2 products for ingest using the pointset plugin.  
	 Updated to replace RR with Rain_Rain; avoids conflict with RR derived param radar reflectivity
         1/6/2020 Commented out TPW, Rain Rate, SST, CLW, WSPD_QC for performance testing
         3/2/2020 Commented out 12 MW Channels not used for current OTE evaluations. Kept 89AH, 89AV, 36H, 36V
         9/5/2023 Changes NASA_Team_2_Ice_Concentration parameter abbrev from ICEC to SeaIce per Carl Dierking/Alaska Region
         9/5/2023 Changes NASA_Team_2_Multiyear_Ice parameter abbrev from MYICE to Multiyear Ice per Carl Dierking/Alaska Region
         9/14/2023 Added Snow_Depth for Alaska Region
    -->
    <!-- TOWRdocs POC
         Lee Byerle  9/14/2023
    -->

<pointSetProductDescriptions>
  <default>
    <matches>
      <match pattern="AMSR2">
        <attribute name="instrument_name"/>
      </match>
    </matches>

    <dataTime>
      <formattedRefTime dateFormat="yyyy-MM-dd'T'HH:mm:ss.S'Z'">
        <attribute name="time_coverage_start" />
      </formattedRefTime>
    </dataTime>

    <datasetId>
      <attribute name="instrument_name" />
    </datasetId>

    <triangulation type="grid" />

    <level>
      <masterLevel>
        <value value="EA" />
      </masterLevel>
      <levelOneValue>
        <value value="0.0" />
      </levelOneValue>
    </level>
  </default>


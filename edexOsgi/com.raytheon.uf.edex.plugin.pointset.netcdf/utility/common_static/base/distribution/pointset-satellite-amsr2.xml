    <!-- TOWRdocs Description
         Distribution file for AMSR2 and other products. It contains the regular expressions
         which search the file name patterns for ingest into edex.

            Patterns reserved for GCOM AMSR-2
                TIOB99
            Patterns reserved for GCOM AMSR-2 Microwave Imagery
                TIAB99
            SNPP ATMS TPW and Rain Rate
                TIMB99
            GPM Imagery 36.5GHz V,H, 89.0GHz V,H for Channel 6-9
                TINB06-09
                TINC06-09
                TINI06-09
                TINQ06-09

    RADARSAT-2 and Sentinel-1A are handled in pointset-satellite-sar.xml.
    VIIRS Red Visible Band (0.67 micron) is handled in /edex_static/distribution/viirs.

    AMSR2 products are available as version 1 and 2 (v1/v2), and the regex expressions are updated
    below to account for both versions.
    -->
    <!-- TOWRdocs Status
       Update for different versions of product 
       10/26/2020 comment out wmo headers setction
    -->
    <!-- TOWRdocs POC
         Lee Byerle 10/26/2020
    -->
<requestPatterns plugin="pointset">
<!-- AMSR2 Updates -->
     <regex>^AMSR2-OCEAN_v\dr\d_GW1_s\d{15}_e\d{15}_c\d{15}\.nc$</regex>
     <regex>^AMSR2-MBT_v\dr\d_GW1_s\d{15}_e\d{15}_c\d{15}\.nc$</regex>
     <regex>^AMSR2-PRECIP_v\dr\d_GW1_s\d{15}_e\d{15}_c\d{15}\.nc$</regex>
  

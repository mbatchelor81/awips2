<!-- 
the default description applies for all subsequent descriptions and defines

- match pattern
- dataTime definition
- master level
- grid coverage

each "product" defines two descriptions:

1. data
2. quality flags

9/7/2024 quality flags commented out
4/2/2025 use time coverage end not start

-->

<gridProductDescriptions>
    <default>
        <matches>
            <match pattern="BHP_ALPW">
                <attribute name="title"/>
            </match>
        </matches>

        <dataTime>
            <formattedRefTime dateFormat="yyyy-MM-dd'T'HH:mm:ss">
                <attribute name="time_coverage_end" />
            </formattedRefTime>
        </dataTime>

	<datasetId>
	    <value value="BHP-ALPW" />
    	</datasetId>

        <coverage>
            <latLonGridCoverage />
            <coordinateLists>
                <latitude>
                    <variable name="lat"/>
                </latitude>
                <longitude>
                    <variable name="lon"/>
                </longitude>
            </coordinateLists>
        </coverage>
    </default>

    <!-- sfc to 850 hPa -->
    <description>
        <data>
            <variable name="ALPW_SFC_850"/>
        </data>
        <parameter>
            <name>
                <value value="ALPW - surface to 850 hPa layer"/>
            </name>
            <units>
                <value value="mm"/>
            </units>
            <abbreviation>
                <value value="ALPW_SFC_850_layers"/>
            </abbreviation>
        </parameter>
        <level>
            <masterLevel>
                <value value="LYRMB"/> <!-- layer btwn 2 isobaric surfaces -->
            </masterLevel>
            <levelOneValue>
                <value value="0.0"/>
            </levelOneValue>
            <levelOneValue>
                <value value="850.0"/>
            </levelOneValue>
        </level>
    </description>

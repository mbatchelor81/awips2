    <!-- TOWRdocs Description
              Edex Description for global mosaic imagery. 
   -->
    <!-- TOWRdocs Status
         12/26/2019 Mercator grid coverage
         1/6/2020   Use instrument_name match pattern
        10/22/2020 set units to "" (reads the product units val of none by default)
    -->
    <!-- TOWRdocs POC
        Lee Byerle 10/22/2020
    -->
<gridProductDescriptions>
  <default>
    <matches>
      <match pattern="GLOBCOMPSIR">
        <attribute name="instrument_name"/>
      </match>
    </matches> 

    <dataTime>
      <formattedRefTime dateFormat="yyyy-MM-dd'T'HH:mm:ss">
        <attribute name="time_coverage_start" />
      </formattedRefTime>
    </dataTime>

    <level>
      <masterLevel>
        <value value="EA" />
      </masterLevel>
      <levelOneValue>
        <value value="0.0" />
      </levelOneValue>
    </level>

    <datasetId>
      <value value="GLOB_COMPSIR" />
    </datasetId>  

    <coverage coverageFile="netcdf/grids/GlobcompGridCoverage_mercator4999.xml" />

  </default>

  <description>
    <data>
      <variable name="data" />  <!-- netCDF file variable -->
    </data>

   <parameter>
      <abbreviation>
        <value value="GLOBALCOMPSIR" /> <!--Arbitrary assigned parameter, point to this in netcdfGrid style rules -->
      </abbreviation>
      <name>
        <value value="Global Composite SWIR" /> <!--Appears in CAVE display legend -->
      </name>
      <units>
        <value value="" />  <!-- units must match those of netCDF file, set as desired in style rules -->
      </units>
    </parameter>
  </description>

</gridProductDescriptions>

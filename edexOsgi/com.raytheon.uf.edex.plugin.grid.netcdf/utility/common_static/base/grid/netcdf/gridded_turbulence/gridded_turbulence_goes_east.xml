            <variable name="probability_30-33" />  <!-- netCDF file variable -->
        </data>

        <parameter>
            <abbreviation>
                <value value="GridTurbGOESEast" /> <!-- Arbitrary assigned parameter, point to this in netcdfGrid style rules -->
            </abbreviation>

            <name>
                <value value="Turbulence Probability" /> <!-- Appears in CAVE display legend -->
            </name>
        </parameter>
    
        <level>

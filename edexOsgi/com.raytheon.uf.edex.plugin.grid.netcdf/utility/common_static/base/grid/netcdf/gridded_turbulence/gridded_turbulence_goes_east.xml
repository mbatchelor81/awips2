<!-- L. Byerle 11/11/2022 Update datasetId no spaces -->
<gridProductDescriptions>
    <default>
        <matches>
            <match pattern="UWSSEC_AWIPS_L\d-TURBF-M\d_G|d{2}_s\d{14}_e\d{14}_c\d{14}.nc">
                <attribute name="dataset_name"/>
            </match>

            <match pattern="G19">
                <attribute name="platform_ID"/>
            </match>
        </matches>

        <dataTime>
            <formattedRefTime dateFormat="yyyy-MM-dd'T'HH:mm:ss'Z'">
                <attribute name="time_coverage_start" />
            </formattedRefTime>
        </dataTime>

        <datasetId>
		<value value="GOES-East_Gridded_Turbulence" />
		<!--<value value="GOES-East Gridded Turbulence" /> -->
        </datasetId>

        <coverage coverageFile="netcdf/grids/GriddedTurbulence_LatLon_GOESEast.xml" />
    </default>


<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<styleRuleset>

    <!-- SSEC LightningCast Style Rules --> 
    <!-- L. Byerle 11/10/2022 added displayUnits -->

    
    <!-- Single layer product -->
    <styleRule>
        <paramLevelMatches>
            <parameter>GridTurbGOESEast</parameter>
            <parameter>GridTurbGOESWest</parameter>
        </paramLevelMatches>
        <contourStyle>
               <displayUnits>%</displayUnits>
            <contourLabeling>
                <values color="#003666" lineStyle="SOLID" thickness="3">10</values>
                <values color="#0b8180" lineStyle="SOLID" thickness="3">20</values>
                <values color="#6aa84f" lineStyle="SOLID" thickness="3">33</values>
                <values color="#ffff00" lineStyle="SOLID" thickness="3">50</values>
            </contourLabeling>
        </contourStyle>
    </styleRule>

</styleRuleset>

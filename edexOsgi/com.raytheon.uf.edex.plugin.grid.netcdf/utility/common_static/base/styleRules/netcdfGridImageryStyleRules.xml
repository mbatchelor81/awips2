   <!-- Blended Hydro products -->
    <styleRule>
         <paramLevelMatches>
          <parameter>BLENDED_TPW</parameter>
        </paramLevelMatches>
    <imageStyle>
      <displayUnits>in</displayUnits>
      <range scale="LINEAR">
        <minValue>0</minValue>
        <maxValue>3</maxValue> 
      </range>
       <defaultColormap>GOES-R/GOESR-L2/color-pw10-10</defaultColormap>
       <colorbarLabeling>
        <values>0 .5 1 1.5 2 2.5 3</values>
      </colorbarLabeling>
    </imageStyle>

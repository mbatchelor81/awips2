  <!-- TOWRdocs Header
        Netcdf Grid Imagery style rules.
   -->
   <!-- TOWRdocs Description
        This file sets style for IMERG and other gridded products currently handled with the netcdfGrid plugin.  This file 
	controls display legends, units and color tables for the GPM IMERG-Early and IMERG-Late precipitation
	products. It is a new file not included in the 16.2.1 AWIPS baseline. Configuration for CMORPH is also included

	The default display for gridded data in AWIPS 2 is contour.  An updated to FieldDisplayTypes is added in 
	this collection under /cave_static/../volumebrowser to make the defaults for IMERG (for example) be "IMAGE" displays.
	With this implementation, the style rules below are activated.

	The color table and increments below currently match those of the GOES-R WFO collection of localization files.
    Restart CAVE whenever making changes to this file.  The RR/QPE color table points to the default in the Sat/GOESR-L2 directory.

   -->
   <!-- TOWRdocs Status
        Update to baseline file to add blended hydro style rules
        Ensure units for hours is the letter "h"
        Labels for satellite number
        11/19/2022 add flood maps
        7/28/2023  dataMapping add NOAA-21,Metop-C, rm Metop-A, rm GPS (Rain Rate) Blended Hydro. 
        9/5/2023   Include CMORPH2 (for Alaska Region only currently) 
        4/17/2024 Added comment Floodwater field works for both VIIRS and ABI flood maps
        9/7/2024  ALPW
        1/6/2025 Fix BLENDED_RR units to display in/hour, matching colormap 
   -->
   <!-- TOWRdocs POC
        Lee Byerle 1/6/2025
   -->
<styleRuleset>
   <!-- Blended Hydro products -->
    <styleRule>
         <paramLevelMatches>
          <parameter>BLENDED_TPW</parameter>
        </paramLevelMatches>
    <imageStyle>
      <displayUnits>in</displayUnits>
      <range scale="LINEAR">
        <minValue>0</minValue>
        <maxValue>3</maxValue> 
      </range>
       <defaultColormap>GOES-R/GOESR-L2/color-pw10-10</defaultColormap>
       <colorbarLabeling>
        <values>0 .5 1 1.5 2 2.5 3</values>
      </colorbarLabeling>
    </imageStyle>
    </styleRule>

   <styleRule>
         <paramLevelMatches>
          <parameter>BLENDED_TPW_Obs_age</parameter>
        </paramLevelMatches>
    <imageStyle>
      <interpolate>false</interpolate>
      <displayUnits label="hr">*1</displayUnits>
      <range scale="LINEAR">
        <minValue>0</minValue>
        <maxValue>12</maxValue>
      </range>
       <defaultColormap>GOES-R/GOESR-L2/color-pw10-10</defaultColormap>
       <colorbarLabeling>
        <values>0 2 4 6 8 10</values>
      </colorbarLabeling>
    </imageStyle>
    </styleRule>

   <styleRule>
         <paramLevelMatches>
          <parameter>BLENDED_TPW_Sat_Number</parameter>
        </paramLevelMatches>
    <imageStyle>
      <interpolate>false</interpolate>
      <displayUnits label="">*1</displayUnits>
      <range>
        <minValue>-100</minValue>
        <maxValue>1100</maxValue> 
      </range>
       <defaultColormap>GOES-R/GOESR-L2/color-pw10-10</defaultColormap>
      <dataMapping>
                <entry pixelValue='19'   displayValue='19'   label="NOAA-19" />
                <entry pixelValue='20'   displayValue='20'   label="NOAA-20" />
                <entry pixelValue='21'   displayValue='21'   label="NOAA-21" />
                <entry pixelValue='102'  displayValue='102'  label="Metop-B" />
                <entry pixelValue='103'  displayValue='103'  label="Metop-C" />
                <entry pixelValue='301'  displayValue='301'  label="S-NPP" />
                <entry pixelValue='401'  displayValue='401'  label="GCOM" />
                <entry pixelValue='501'  displayValue='501'  label="GPM" />
                <entry pixelValue='1001' displayValue='1001' label="GPS" />
      </dataMapping>
    </imageStyle>
    </styleRule>


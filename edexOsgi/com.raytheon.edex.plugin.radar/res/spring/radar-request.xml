<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.springframework.org/schema/beans
    http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="getRadarDataTreeHandler" class="com.raytheon.edex.plugin.radar.handler.GetRadarDataTreeHandler" />
    <bean id="getRadarDataRecordHandler" class="com.raytheon.edex.plugin.radar.handler.GetRadarDataRecordHandler" />

    <bean id="radarVbMenuUtil" class="com.raytheon.edex.plugin.radar.util.RadarVBMenuUtil" />
    <bean id="radarVbMenus" factory-bean="menuCreationRegistry" factory-method="register">
        <constructor-arg value="radarVb"/>
        <constructor-arg ref="radarVbMenuUtil"/>
    </bean>

</beans>
<backupServiceConfig xmlns:ns2="group">

    <!-- localDomains are the sub domains for which your local Edex should create
         Outgoing Backup Jobs for and send to the hosts configured below. This is
         optional, if excluded only the Edex Site will be used. This should not
         contain other SITES outside your local sub domains. When configured you 
         aren't required to put the Edex Site, as the software will automatically
         include it. -->
    <!--
    <localDomains>
        <domain>ALU</domain>
        <domain>AER</domain>
    </localDomains>
    -->
    
    <!-- Hosts are in descending order of priority. Port and filterDomains are optional. 
         The filterDomains tag specifies which SITE and CONFIGURED level files should be
         sent to that host for the listed domains. By default all files that meet the 
         include filters are sent to each host. Unlike the localDomain the Edex Site does
         need to be added in each filterDomain configuration that you want to send
         those files to.-->
    <!--
    <hosts>
    <host>
        <site>OAX</site>
        <hostName>ev-oax</hostName>
        <port>9581</port>
    </host>
    <host>
        <site>DMX</site>
        <hostName>ev-dmx</hostName>
    </host>
    <host>
        <site>AJK</site>
        <filterDomains>
            <domain>AFC</domain>
            <domain>AER</domain>
        </filterDomains>
        <hostName>ev-ajk</hostName>
    </host>
    <host>
        <site>AFG</site>
        <filterDomains>
            <domain>AFC</domain>
            <domain>ALU</domain>
        </filterDomains>
        <hostName>ev-afg</hostName>
    </host>
    </hosts>
      -->

    <!-- How often to check for new jobs. This feature is only used by legacy Backup Services features. -->
    <!-- <pollIntervalSeconds>300</pollIntervalSeconds> -->

    <!-- Limit sending of requests to this many kbytes per second on average -->
    <!-- <rateLimitKBps>16</rateLimitKBps> -->

    <!-- Log a warning before processing any job bigger than this (bytes) -->
    <!-- <bigJobSize>5242880</bigJobSize> -->

    <!-- Purge ACCEPTED or REJECTED backup service jobs when they are older than the 
         specified number of days. -->
    <!-- <purgeTimePeriodDays>14</purgeTimePeriodDays> -->

    <!-- Edex version cutoff from using the current Backup Service.
        Note: edexCutoffVersion signifies the minimum version number a Recipient Site 
        must have to use the new functionality of Backup Services, otherwise  any 
        Backup Jobs sent to Recipient sites with versions lower than 
        21.4.1 will use the pre 21.4.1 functionality. 
    -->
    <!-- <edexCutoffVersion>21.4.1</edexCutoffVersion> -->

     <!-- The <include> tag lists all localization paths that will be sent to 
          backup sites when a file at any path changes. The SITE version of this file 
          adds to the BASE version, and all other levels are ignored. 
          
          The format is: 
               <include> 
                    <file level="localization_level"> localization_type/subpath/to/file </file> 
                    <file level="localization_level"> localization_type/subpath/to/file2</file>
                    <file>... 
               </include> 
          
          A simple example would be: 
               <include> 
                    <file level="SITE">common_static/textdb/textCategoryClass.txt</file> 
               </include> 
               
           You can use * to match any level, type, or any part of a path. For example, to match 
          all SITE afos2awips files: 
               <include> 
                    <file level="SITE" >common_static/afos2awips/*</file> 
               </include> 
     -->           
          
     <!-- Uncomment below to use: -->
     <!-- 
          <include>
                   <file level="REGION" >*</file>
                   <file level="SITE">*</file>
                   <file level="CONFIGURED">*</file>
          </include>
     -->



     <!-- The <exclude> tag lists all localization paths that will NOT 
          be sent to backup sites. This file overrides the whitelist in the <include> 
          tag above. That is, the <include> tag is checked first to determine which 
          files are sent out, then the <exclude> tag determines which among those are 
          NOT sent. The SITE version of this file adds to the BASE version, and all 
          other levels are ignored. 
          
          The format is: 
              <exclude> 
                   <file level="localization_level">localization_type/subpath/to/file </file> 
                   <file level="localization_level">localization_type/subpath/to/file2 </file> 
                   <file>... 
              </exclude> 
              
          A simple example would be: 
          
          <exclude> 
               <file level="SITE">common_static/textdb/textCategoryClass.txt</file> 
          </exclude> 
          
          You can use * to match any level, type, or any part of a path. 
          For example, to match all SITE afos2awips files: 
          
          <exclude> 
               <file level="SITE">common_static/afos2awips/*</file> 
          </exclude> 
          
          BASE is hard-coded to never send to backup sites, but is included 
          anyway for safety. 
     -->

     <exclude>
          <file level="BASE">*</file>
          <file level="WORKSTATION">*</file>
          <file level="USER">*</file>
          <file level="SITE">common_static/backupSvc/*</file>
          <file level="*">*.pyc</file>
          <file level="*">*.ini</file>
          <file level="*">*.cfg</file>
     </exclude> 

</backupServiceConfig>
